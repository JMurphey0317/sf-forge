{
  "manifest_version": 3,
  "name": "SF Forge",
  "version": "5.1.1",
  "description": "Dark Fenrir Forge Salesforce productivity toolkit \u2014 v5.1.1 with GitHub auto-update checker, 11 new tools, and security hardening.",
  "author": "Dark Fenrir Forge",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_title": "SF Forge",
    "default_popup": "src/popup/popup.html"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "identity",
    "scripting",
    "cookies",
    "downloads",
    "sidePanel",
    "activeTab",
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://test.salesforce.com/services/*",
    "https://login.salesforce.com/services/*",
    "https://*.force.com/services/*",
    "https://*.lightning.force.com/services/*",
    "https://*.my.salesforce.com/services/*",
    "https://*.salesforce.com/services/*",
    "https://*.sandbox.my.salesforce.com/services/*",
    "https://*.site.com/services/*",
    "https://*.visualforce.com/services/*",
    "https://*.force.com/*",
    "https://*.lightning.force.com/*",
    "https://*.my.salesforce.com/*",
    "https://*.salesforce.com/*",
    "https://*.sandbox.my.salesforce.com/*",
    "https://*.site.com/*",
    "https://*.visualforce.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.lightning.force.com/*",
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.my.salesforce.com/*",
        "https://*.sandbox.my.salesforce.com/*",
        "https://*.visualforce.com/*",
        "https://*.site.com/*"
      ],
      "js": [
        "src/content/salesforce-detector.js",
        "src/content/session-bridge.js",
        "src/content/lwc-lens.js"
      ],
      "css": [
        "src/content/lwc-lens.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/brand/*",
        "assets/icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_page": "src/app/index.html",
  "side_panel": {
    "default_path": "src/app/index.html"
  }
}